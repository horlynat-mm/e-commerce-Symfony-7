{% extends 'base.html.twig' %}

{% block title %}Gestion des Catégories
{% endblock %}

{% block body %}
	<div class="container mx-auto my-10">
    
		<h1 class="text-3xl mb-6 font-bold text-center text-gray-800 dark:text-white">Gestion des Catégories</h1>

		<div class="flex justify-end mb-6">
			<a href="{{ path('category_add') }}" class="inline-flex items-center px-6 py-2 text-gray-700 bg-gradient-to-r from-green-400 to-green-600 rounded-lg shadow-md hover:from-green-500 hover:to-green-700 transition duration-300">
				<svg class="w-5 h-5 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
				</svg>
				Nouvelle catégorie
			</a>
		</div>

		<div class="relative w-full overflow-x-auto shadow-lg rounded-lg">
			<table class="w-full text-sm text-left text-gray-700 dark:text-gray-300">
				<thead class="text-xs uppercase bg-gradient-to-r from-indigo-500 to-purple-700 text-white">
					<tr>
						<th scope="col" class="px-6 py-3">Id</th>
						<th scope="col" class="px-6 py-3">Nom</th>
						<th scope="col" class="px-6 py-3 text-center">Actions</th>
					</tr>
				</thead>
				<tbody>
					{% for category in categories %}
						<tr class="bg-white border-b text-gray-700 dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 transition duration-300 ease-in-out">
							<td class="px-6 py-4 font-medium text-gray-900 dark:text-gray-100">{{ category.id }}</td>
							<td class="px-6 py-4">{{ category.name }}</td>
							<td class="flex justify-center items-center space-x-4 px-6 py-4">
								<a href="{{ path('category_read', {'slug': category.slug}) }}" class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-blue-500 rounded-lg hover:bg-blue-600 dark:bg-blue-400 dark:hover:bg-blue-500 transition duration-300">
									<svg class="w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12H9m6 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
									</svg>
									Voir
								</a>
								<a href="{{ path('category_update', {'slug': category.slug}) }}" class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-yellow-500 rounded-lg hover:bg-yellow-600 dark:bg-yellow-400 dark:hover:bg-yellow-500 transition duration-300">
									<svg class="w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 17l-2-2m0 0l-2-2m2 2l2-2m-2 2v6m8 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
									</svg>
									Modifier
								</a>
								<a href="{{ path('category_delete', {'id': category.id}) }}" class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-red-500 rounded-lg hover:bg-red-600 dark:bg-red-400 dark:hover:bg-red-500 transition duration-300">
									<svg class="w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
									</svg>
									Supprimer
								</a>
							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="3" class="px-6 py-4 text-center text-gray-500 dark:text-gray-400 font-medium">Aucune catégorie trouvée.</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>
	</div>
{% endblock %}
