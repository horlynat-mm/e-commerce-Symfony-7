{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="flex items-center p-4 mb-4 text-sm rounded-lg shadow-md
                    {{ label == 'success' ? 'text-green-800 bg-green-100 dark:bg-green-900 dark:text-green-200' :
                       (label == 'error' ? 'text-red-800 bg-red-100 dark:bg-red-900 dark:text-red-200' :
                       (label == 'info' ? 'text-blue-800 bg-blue-100 dark:bg-blue-900 dark:text-blue-200' :
                       'text-gray-800 bg-gray-100 dark:bg-gray-900 dark:text-gray-200')) }}">

            <!-- Icône -->
            <svg aria-hidden="true" class="flex-shrink-0 w-5 h-5 mr-3" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
                {% if label == 'success' %}
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-10.707a1 1 0 00-1.414-1.414L9 9.586 7.707 8.293a1 1 0 10-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                {% elseif label == 'error' %}
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm-3.707-10.707a1 1 0 011.414 0L10 10.586l2.293-2.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-2-2a1 1 0 010-1.414z" clip-rule="evenodd"/>
                {% elseif label == 'info' %}
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm-1-11a1 1 0 012 0v5a1 1 0 01-2 0V7zm1-2a1 1 0 110 2 1 1 0 010-2z" clip-rule="evenodd"/>
                {% else %}
                    <circle cx="10" cy="10" r="4"/>
                {% endif %}
            </svg>

            <!-- Message -->
            <span class="font-medium">{{ message|raw }}</span>

            <!-- Bouton Fermer -->
            <button type="button" class="ml-auto inline-flex items-center justify-center w-6 h-6 text-gray-400 bg-transparent rounded-lg hover:bg-gray-200 hover:text-gray-900 focus:ring-2 focus:ring-gray-400 dark:hover:bg-gray-600 dark:hover:text-white" aria-label="Close" data-dismiss-target="#alert" aria-hidden="true">
                <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>
    {% endfor %}
{% endfor %}
