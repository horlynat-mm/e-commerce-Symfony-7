{% extends 'base.html.twig' %}

{% block title %}New Product{% endblock %}

{% block body %}
    <h1 class="text-3xl font-bold text-center text-gray-800 dark:text-white mt-5">
        <span class="bg-gradient-to-r from-blue-500 to-teal-500 text-transparent bg-clip-text">
            Créer un nouveau produit
        </span>
    </h1>

    <div class="max-w-lg mx-auto bg-white rounded-lg shadow-md p-6 mt-8 dark:bg-gray-800">

        {{ include('product/_form.html.twig') }}

        <a href="{{ path('product_list') }}" class="mt-4 inline-block px-5 py-2 text-sm font-medium text-gray-600 bg-gray-200 rounded-lg shadow-sm hover:bg-gray-300 dark:bg-gray-700 dark:text-gray-100 dark:hover:bg-gray-600 transition-all duration-300">
            Retour à la liste des produits
        </a>
    </div>
{% endblock %} 