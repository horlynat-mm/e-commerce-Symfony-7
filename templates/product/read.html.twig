{% extends 'base.html.twig' %}

{% block title %}Détails du produit{% endblock %}

{% block body %}
<div class="container mx-auto mt-10">
    <h1 class="text-3xl font-bold text-center text-gray-800 dark:text-white mb-6">Détails du produit</h1>

    <div class="max-w-3xl mx-auto bg-white rounded-lg shadow-lg dark:bg-gray-800 p-6">
        <table class="w-full text-sm text-left text-gray-700 dark:text-gray-300 border border-gray-200 dark:border-gray-700">
            <tbody>
                <tr class="border-b dark:border-gray-700">
                    <th scope="row" class="px-6 py-4 font-medium text-gray-900 dark:text-gray-100">ID</th>
                    <td class="px-6 py-4">{{ product.id }}</td>
                </tr>
                <tr class="border-b dark:border-gray-700">
                    <th scope="row" class="px-6 py-4 font-medium text-gray-900 dark:text-gray-100">Nom</th>
                    <td class="px-6 py-4">{{ product.name }}</td>
                </tr>
                <tr class="border-b dark:border-gray-700">
                    <th scope="row" class="px-6 py-4 font-medium text-gray-900 dark:text-gray-100">Description</th>
                    <td class="px-6 py-4">{{ product.description }}</td>
                </tr>
                <tr class="border-b dark:border-gray-700">
                    <th scope="row" class="px-6 py-4 font-medium text-gray-900 dark:text-gray-100">Prix</th>
                    <td class="px-6 py-4">{{ product.price }} €</td>
                </tr>
                <tr class="border-b dark:border-gray-700">
                    <th scope="row" class="px-6 py-4 font-medium text-gray-900 dark:text-gray-100">Stock</th>
                    <td class="px-6 py-4">{{ product.stock }}</td>
                </tr>
                <tr class="border-b dark:border-gray-700">
                    <th scope="row" class="px-6 py-4 font-medium text-gray-900 dark:text-gray-100">Valide</th>
                    <td class="px-6 py-4">{{ product.isValid ? 'Oui' : 'Non' }}</td>
                </tr>
                <tr class="border-b dark:border-gray-700">
                    <th scope="row" class="px-6 py-4 font-medium text-gray-900 dark:text-gray-100">Slug</th>
                    <td class="px-6 py-4">{{ product.slug }}</td>
                </tr>
                <tr>
                    <th scope="row" class="px-6 py-4 font-medium text-gray-900 dark:text-gray-100">Catégorie</th>
                    <td class="px-6 py-4">{{ product.category.name }}</td>
                </tr>
            </tbody>
        </table>

        <div class="flex justify-between mt-6">
            <!-- Bouton Retour -->
            <a href="{{ path('product_list') }}" class="px-6 py-2 text-sm font-medium text-gray-700 bg-gray-200 rounded-lg shadow hover:bg-gray-300 dark:bg-gray-700 dark:text-gray-200 dark:hover:bg-gray-600 transition-all duration-300">
                Retour à la liste
            </a>

            <!-- Bouton Modifier -->
            <a href="{{ path('product_update', {'slug': product.slug}) }}" class="px-6 py-2 text-sm font-medium text-white bg-blue-500 rounded-lg shadow hover:bg-blue-600 dark:bg-blue-400 dark:hover:bg-blue-500 transition-all duration-300">
                Modifier
            </a>

            <!-- Bouton Supprimer -->
            <div>
                {{ include('product/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
