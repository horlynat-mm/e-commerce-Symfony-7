{% extends 'base.html.twig' %}

{% block title %}Liste des Produits
{% endblock %}

{% block body %}

	<div class="container mx-auto my-10">
		<!-- Titre principal -->
		<h1 class="text-4xl font-bold text-center text-gray-800 dark:text-white mb-8">
			Liste des Produits
		</h1>

		<!-- Section Bouton Nouveau Produit -->
		<div class="w-full flex justify-end mb-6">
			<a href="{{ path('product_add') }}" class="inline-flex items-center px-6 py-2 text-gray-700 bg-gradient-to-r from-green-400 to-green-600 rounded-lg shadow-md hover:from-green-500 hover:to-green-700 transition duration-300">
				<svg class="w-5 h-5 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
				</svg>
				Nouveau Produit
			</a>
		</div>

		<!-- Tableau des Produits -->
		<div class="relative w-full overflow-x-auto shadow-lg rounded-lg">
			<table class="w-full text-sm text-left text-gray-700 dark:text-gray-300">
				<thead class="text-xs uppercase bg-gradient-to-r from-indigo-500 to-purple-700 text-white">
					<tr>
						<th scope="col" class="px-6 py-3">Id</th>
						<th scope="col" class="px-6 py-3">Nom</th>
						<th scope="col" class="px-6 py-3">Description</th>
						<th scope="col" class="px-6 py-3">Prix</th>
						<th scope="col" class="px-6 py-3">Stock</th>
						<th scope="col" class="px-6 py-3">Valide</th>
						<th scope="col" class="px-6 py-3">Catégorie</th>
						<th scope="col" class="px-6 py-3 text-center">Actions</th>
					</tr>
				</thead>
				<tbody>
					{% for product in products %}
						<tr class="bg-white border-b dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 transition duration-300 ease-in-out">
							<td class="px-6 py-4 font-medium text-gray-900 dark:text-gray-100">{{ product.id }}</td>
							<td class="px-6 py-4">{{ product.name }}</td>
							<td class="px-6 py-4">{{ product.description }}</td>
							<td class="px-6 py-4">{{ product.price }}
								€</td>
							<td class="px-6 py-4">{{ product.stock }}</td>
							<td class="px-6 py-4">{{ product.isValid ? 'Oui' : 'Non' }}</td>
							<td class="px-6 py-4">{{ product.category ? product.category.name : 'Non catégorisé' }}</td>
							<td class="flex justify-center items-center space-x-4 px-6 py-4">
								<a href="{{ path('product_read', {'slug': product.slug}) }}" class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-blue-500 rounded-lg hover:bg-blue-600 dark:bg-blue-400 dark:hover:bg-blue-500 transition duration-300">
									Voir
								</a>
								<a href="{{ path('product_update', {'slug': product.slug}) }}" class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-yellow-500 rounded-lg hover:bg-yellow-600 dark:bg-yellow-400 dark:hover:bg-yellow-500 transition duration-300">
									Modifier
								</a>
								<form method="post" action="{{ path('product_delete', {'id': product.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce produit ?');">
									<button class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-red-500 rounded-lg hover:bg-red-600 dark:bg-red-400 dark:hover:bg-red-500 transition duration-300">
										Supprimer
									</button>
								</form>
							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="8" class="px-6 py-4 text-center text-gray-500 dark:text-gray-400 font-medium">
								Aucun produit trouvé.
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>
	</div>
{% endblock %}
